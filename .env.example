# Rock runtime settings
TZ=America/Toronto
PUID=1000
PGID=1000

# Optional cloud agent credentials
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=

# Optional OpenAI-compatible local or private LLM endpoint.
# From inside Rock, use host.docker.internal rather than localhost when the
# model server or SSH tunnel runs on the Docker host.
ROCK_LOCAL_LLM_BASE_URL=
ROCK_LOCAL_LLM_API_KEY=not-needed
ROCK_LOCAL_LLM_MODEL=local-model
ROCK_LOCAL_LLM_MAX_TOKENS=4096
ROCK_LOCAL_LLM_TEMPERATURE=0.2
ROCK_LOCAL_LLM_TIMEOUT_SECONDS=120

# Optional AGY installation during image build
ROCK_INSTALL_AGY=0
ROCK_AGY_INSTALL_COMMAND=curl -fsSL https://antigravity.google/cli/install.sh | bash
